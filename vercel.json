{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/docs",
      "destination": "/docs/"
    },
    {
      "source": "/:path((?!docs(?:/|$)|assets(?:/|$)|.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
