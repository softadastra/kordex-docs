{
  "name": "kordex-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Kordex website and documentation.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:docs": "vitepress dev docs --host 0.0.0.0 --port 5174",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:docs\"",
    "clean": "rm -rf dist docs/.vitepress/dist docs/.vitepress/cache",
    "build:app": "vite build",
    "build:docs": "vitepress build docs",
    "build": "npm run clean && npm run build:app && npm run build:docs",
    "preview": "vite preview --host 0.0.0.0",
    "preview:docs": "vitepress preview docs --host 0.0.0.0 --port 4174",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:softadastra/kordex-docs.git"
  },
  "keywords": [
    "kordex",
    "softadastra",
    "runtime",
    "vitepress",
    "vue"
  ],
  "author": "Softadastra",
  "license": "MIT",
  "dependencies": {
    "vue": "^3.5.33",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.2.1",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4",
    "mark.js": "^8.11.1",
    "minisearch": "^7.2.0"
  }
}
